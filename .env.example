# MongoDB Connection URI
# Use MongoDB Atlas cloud URI or local instance
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/db_green?retryWrites=true&w=majority
# MONGO_URL=mongodb://localhost:27017/db_green

# Nodemailer Gmail credentials
# Use an App Password (not your real Gmail password)
# See: https://support.google.com/accounts/answer/185833
MY_SECRET_EMAILID=your_email@gmail.com
MY_SECRET_PASSWORD=your_gmail_app_password

# Session secret — use a long random string in production
SESSION_SECRET=your_long_random_session_secret_here

# Base URL of your deployed app (used in email links)
BASE_URL=http://localhost:5000

# Server Port (optional, defaults to 5000)
PORT=5000
