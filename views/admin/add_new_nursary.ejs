<main>
	<%- include('../partials/adminSidebar') %>
	
	<div id="main-wrapper">
		<div class="bg-white shadow-sm p-3">
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block">Add New Nursery</h5>
		</div>
		
		<form action="/admin/save_new_nursary" method="POST" class="border m-4 my-3 p-4 bg-white rounded-2 shadow">
		
			
			<div class="row">
				<div class="mb-4 col-sm-6">
					<label for="quantity" class="form-label">name</label>
					<input type="text" name="name" class="form-control" id="quantity"  required>
				</div>

                <div class="mb-4 col-sm-6">
					<label for="quantity" class="form-label">Address</label>
					<input type="text" name="address" class="form-control" id="quantity"  required>
				</div>

                <div class="mb-4 col-sm-6">
					<label for="quantity" class="form-label">caretaker</label>
					<input type="text" name="caretaker" class="form-control" id="quantity"  required>
				</div>

                <div class="mb-4 col-sm-6">
					<label for="quantity" class="form-label">Phone No</label>
					<input type="number" name="phone" class="form-control" id="quantity"  required>
				</div>
				
				
			</div>

	
			
			
		
			
			<button type="submit" class="btn w-75 d-block m-auto mt-4">Submit</button>
		</form>
		
	</div>
</main>

