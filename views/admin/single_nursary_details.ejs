<main>
	<%- include('../partials/adminSidebar') %>
	
	<div id="main-wrapper">
		
		<div class="bg-white shadow-sm p-3">
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block">Plants Details of <%= nursary_d.name %>- Nursery</h5>
		</div>

   
       
            
            <form action="/admin/add_plant_to_nursary" method="POST" class="border m-4 my-3 p-4 bg-white rounded-2 shadow">   
               
    
        
                
                
          
                
                <div class="row">
                    <div class="mb-4 col-sm-8">
                        <input type="hidden" name="nursary_name" id="nursary_name" value="<%=nursary_d.name %>">
                        <input type="hidden" name="nursary_id" id="nursary_id" value="<%=nursary_d._id %>">                       
                        <input type="hidden" name="caretaker" id="caretaker" value="<%=nursary_d.caretaker %>">
                        <input type="hidden" name="address" id="address" value="<%=nursary_d.address %>">
                        <input type="hidden" name="phone" id="phone" value="<%=nursary_d.phone %>">

                        <input type="hidden" name="row_count" id="row_count" >
                        <input type="hidden" name="pl_de" id="pl_de" >



                        <label for="plant_name" class="form-label">plant name</label>
                        <select  class="form-select" id="plant_name"  name="plant_name">
                            <% for(let i=0; i<plants.length; i++) { %>
                                <option value="<%= plants[i].name %>"><%= plants[i].name  %></option>
                            <% } 
                            if(plants.length<1){%>
                                <option value="nil">NIL</option>
        
        
                                <%}
                            %>
                        </select>
                        <!-- <input type="text" name="donation[plant_name]" class="form-control" id="address" placeholder="Enter address.." value="<%= currentUser.address %>" required> -->
                    </div>
                    
                    <div class="mb-4 col-sm-4">
                        <label for="qty" class="form-label">Quantity</label>
                        <input type="number" min="0" name="qty" class="form-control" id="qty" placeholder="Enter Quantity.." required>
                    </div>

                    <div class="mb-4 col-sm-4">
                        <label for="added_date" class="form-label">Date</label>
                        <input type="datetime-local" name="added_date" class="form-control" id="added_date"   required>
                    </div>
                </div>
                
               
                
                <button type="button" class="btn w-75 d-block m-auto mt-4" onclick="add_row()">Add</button>
           
            
        
		
		<div class="col col-sm-10 col-12 m-auto my-4" style="max-height: 75%; overflow: auto;">
			<table class="table table-info table-striped table-hover m-0 bg-white" id="table">
				<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Plant</th>
						<th scope="col">Quantity</th>
						<th scope="col">Added Date</th>
                        <th scope="col">Action</th>
						
						
					</tr>
				</thead>
				<tbody>
					<% 
                    if(nursary_details.length > 0){
                    for(let i=0; i<nursary_details.length; i++) { %>
						<tr>
							<th scope="row"> <%= i+1 %> </th>
							<td> <%= nursary_details[i].plant %> </td>
							<td> <%= nursary_details[i].quantity %> </td>
							
							<td> <%= nursary_details[i].add_date.toLocaleString("en-IN", { dateStyle: "medium", timeStyle: "short"}) %> </td>
							<td>
                                <a href="/admin/nursary_details/delete/<%= nursary_d._id %>/<%= nursary_details[i]._id %>" class="btn">Delete</a>
                            </td>

							
						</tr>
					<% }} %>
				</tbody>
			</table>
		</div>
        <button type="submit" class="btn w-75 d-block m-auto mt-4" ">SAVE</button>
    </form>
	</div>
</main>