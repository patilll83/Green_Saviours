<main>
	<%- include('../partials/adminSidebar') %>
	
	<div id="main-wrapper">
		
		<div class="bg-white shadow-sm p-3">
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block">Details of Plantation Area where <%= currentUser.firstName %> <%=  currentUser.lastName %> has worked </h5>
		</div>
		
		<div class="col col-sm-10 col-12 m-auto my-4" style="max-height: 75%; overflow: auto;">
			<table class="table table-info table-striped table-hover m-0 bg-white">
				<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Plantation Name</th>
						<th scope="col">Added Date</th>
					
					</tr>
				</thead>
				<tbody>
                    <% for(let i=0; i<volunteer_workdone.length; i++) { %>
						<tr>
							<th scope="row"> <%= i+1 %> </th>
							<td> <%= volunteer_workdone[i].plantation_name  %> </td>
							<td> <%= volunteer_workdone[i].added_date.toLocaleString("en-IN", { dateStyle: "medium", timeStyle: "short"}) %> </td>						
							
					<% } %>
				</tbody>
			</table>
		</div>
		
	</div>
</main>