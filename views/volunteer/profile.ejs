<main>
	<%- include('../partials/volenteerSidebar') %>
	
	<div id="main-wrapper">
		
		<div class="bg-white shadow-sm p-3">
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block">My Profile</h5>
		</div>

		<%- include('../partials/alerts') %>
		
		<form action="/volunteer/profile" method="POST" class="w-75 border ms-3 my-3 p-4 bg-white rounded-2 shadow" style="min-width: 400px;">
			
			<div class="row">
				<div class="col-sm-6 mb-4">
					<label for="vol-first-name" class="form-label">First Name</label>
					<input type="text" name="firstName" class="form-control" id="vol-first-name" placeholder="Enter first name.." value="<%= currentUser.firstName %>" required>
				</div>
				
				<div class="col-sm-6 mb-4">
					<label for="vol-last-name" class="form-label">Last Name</label>
					<input type="text" name="lastName" class="form-control" id="vol-last-name" placeholder="Enter last name.." value="<%= currentUser.lastName %>" required>
				</div>
			</div>
			
			<div class="mb-4">
				<label for="vol-email" class="form-label">Email</label>
				<input type="email" id="vol-email" class="form-control" value="<%= currentUser.email %>" disabled>
			</div>
			
			<div class="mb-4">
				<span class="d-inline-block me-2">Gender:</span>
				<div class="form-check form-check-inline">
					<input class="form-check-input" type="radio" name="gender" id="vol-male" value="male" <%= currentUser.gender == 'male' ? 'checked' : '' %>>
					<label class="form-check-label" for="vol-male">Male</label>
				</div>
				<div class="form-check form-check-inline">
					<input class="form-check-input" type="radio" name="gender" id="vol-female" value="female" <%= currentUser.gender == 'female' ? 'checked' : '' %>>
					<label class="form-check-label" for="vol-female">Female</label>
				</div>
			</div>
			
			<div class="mb-4">
				<label for="vol-address" class="form-label">Address</label>
				<input type="text" name="address" class="form-control" id="vol-address" placeholder="Enter address.." value="<%= currentUser.address %>">
			</div>
			
			<div class="mb-4">
				<label for="vol-phone" class="form-label">Phone</label>
				<input type="number" name="phone" class="form-control" id="vol-phone" placeholder="Enter phone.." value="<%= currentUser.phone %>">
			</div>
			
			<button type="submit" class="btn w-75 d-block m-auto mt-4">Update Profile</button>
		</form>
		
	</div>
</main>
