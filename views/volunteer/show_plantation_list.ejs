<main>
	<%- include('../partials/volenteerSidebar') %>
	
	<div id="main-wrapper">
		
		<div class="bg-white shadow-sm p-3">
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block">My Plantations</h5>
		</div>

		<%- include('../partials/alerts') %>

		<div class="col col-sm-10 col-12 m-auto my-4" style="max-height: 75%; overflow: auto;">
			<% if (assignedPlantations.length > 0) { %>
				<table class="table table-info table-striped table-hover m-0 bg-white">
					<thead>
						<tr>
							<th scope="col">#</th>
							<th scope="col">Plantation Name</th>
							<th scope="col">Date Assigned</th>
						</tr>
					</thead>
					<tbody>
						<% assignedPlantations.forEach(function(p, i) { %>
							<tr>
								<th scope="row"><%= i + 1 %></th>
								<td><%= p.plantation_name %></td>
								<td><%= p.added_date ? p.added_date.toLocaleDateString() : 'N/A' %></td>
							</tr>
						<% }) %>
					</tbody>
				</table>
			<% } else { %>
				<div class="alert alert-info m-4">No plantations have been assigned to you yet.</div>
			<% } %>
		</div>
		
	</div>
</main>
