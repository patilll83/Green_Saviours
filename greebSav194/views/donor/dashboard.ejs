<main>
	<%- include('../partials/volenteerSidebar') %>
	
	<div id="main-wrapper">
		
		<div class="bg-white shadow-sm p-3" >
			<span class="me-3" id="sidebar-toggler-btn"><i class="fas fa-bars"></i></span>
			<h5 class="m-0 color-theme d-inline-block" >Dashboard</h5>
		</div>
		
		<div class="d-flex gap-3 flex-wrap m-4 text-white">
		<div  class="m-0 color-theme d-inline-block" style="margin-right: 1500px;width: 700px;"><h3>Notifications</h3></div>	
		
		
		

			<%if (notification.length >0){ %>
				<% notification.forEach(function(row){ %>
				<!-- <tr>
				  <td><%= row.message %></td>
				  <td><%= row.added_date %></td>
				  
				</tr> -->

				<div class="bg-primary rounded p-3" style="width: 700px;">
					<div class="fs-5"><%=row.message %></div>
					<div class="fs-5"><%= row.added_date.toLocaleDateString() %></div>
					
					<!-- <div class="fs-5"><%= row.added_date.toLocaleDateString("fr-CA", {day:"2-digit", month: "2-digit", year:"numeric"}) %></div> -->

					
				</div>
				<% })}
			
				%>
			
		</div>
		
	</div>
</main>